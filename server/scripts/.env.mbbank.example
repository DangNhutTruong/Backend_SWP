# MBBank Real Checker Environment Configuration
# Copy this file to .env.mbbank and fill in your actual credentials

# Backend API Configuration
BACKEND_URL=http://localhost:5000/api

# ⭐⭐⭐⭐ Rate Limiting (1-3 minutes recommended)
# Minimum: 60 seconds, Maximum: 300 seconds
CHECK_INTERVAL=180

# ⭐⭐⭐⭐⭐ MBBank Credentials (REQUIRED - KEEP SECRET!)
# Replace with your actual MBBank login credentials
MBBANK_USERNAME=your_mbbank_username_here
MBBANK_PASSWORD=your_mbbank_password_here
MBBANK_ACCOUNT_NUMBER=0334937028

# Optional: Logging configuration
LOG_LEVEL=INFO
LOG_FILE=mbbank_real_checker.log

# ⭐⭐⭐⭐⭐ SECURITY WARNINGS:
# - NEVER commit this file with real credentials to git
# - Use strong, unique passwords for your MBBank account
# - Consider using app-specific passwords if available
# - Monitor your account regularly for unauthorized access
# - Keep this file permissions restricted (chmod 600 on Linux/Mac)

# ⭐⭐⭐ Error Handling Configuration
MAX_LOGIN_FAILURES=3
LOGIN_COOLDOWN_MINUTES=15

# ⭐⭐⭐⭐ Duplicate Prevention
# Processed transactions are automatically saved to: processed_transactions.json
# This file tracks which transactions have been processed to avoid duplicates
